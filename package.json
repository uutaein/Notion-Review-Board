{
  "name": "notion-review-board",
  "version": "0.1.0",
  "private": true,
  "description": "A document-level spaced repetition desktop app for Notion pages",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run rebuild:native && electron-vite dev",
    "build": "npm run typecheck && npm run rebuild:native && electron-vite build",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild:native",
    "preview": "npm run rebuild:native && electron-vite preview",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run rebuild:node && vitest run --configLoader runner",
    "test:screen": "npm run build && playwright test",
    "test:watch": "npm run rebuild:node && vitest --configLoader runner",
    "test:features": "cucumber-js \"feature/**/*.feature\"",
    "test:features:dry": "cucumber-js \"feature/**/*.feature\" --dry-run --format progress"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ts-fsrs": "^5.4.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "electron": "^40.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
